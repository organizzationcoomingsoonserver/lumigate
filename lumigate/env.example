# ============================================
#   LUMIGATE - Environment Variables
#   Copia questo file in .env e compila i valori
#   Su Vercel: aggiungili in Project > Settings > Environment Variables
# ============================================

# Discord OAuth2
# Ottienili su https://discord.com/developers/applications
DISCORD_CLIENT_ID=IL_TUO_CLIENT_ID
DISCORD_CLIENT_SECRET=IL_TUO_CLIENT_SECRET
DISCORD_REDIRECT_URI=https://lumigate.vercel.app/auth/callback

# ID del tuo server Discord
DISCORD_GUILD_ID=IL_TUO_GUILD_ID

# Webhook Discord per notifiche unban/candidature (opzionale)
DISCORD_WEBHOOK_UNBAN=IL_TUO_WEBHOOK_URL
DISCORD_WEBHOOK_CANDIDATURE=IL_TUO_WEBHOOK_URL

# Segreto per JWT session (stringa random lunga)
JWT_SECRET=cambia_questa_stringa_con_qualcosa_di_random_lungo
